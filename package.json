{
  "name": "3d-artifact-digitisation-hub",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "start": "concurrently 'npm run start --workspace=@3d-hub/management-frontend' 'npm run start --workspace=@3d-hub/management-api'",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "storybook": "npm run storybook --workspace=@3d-hub/management-frontend"
  },
  "devDependencies": {
    "@testcontainers/localstack": "^11.13.0",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.5.3"
  },
  "private": true,
  "workspaces": [
    "frontend",
    "api",
    "infra",
    "packages/*"
  ]
}
