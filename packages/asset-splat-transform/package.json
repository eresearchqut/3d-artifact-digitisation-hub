{
  "name": "@3d-hub/asset-splat-transform",
  "version": "1.0.0",
  "description": "Convert uploaded splat/ply assets to SOG HTML viewer app",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js && cd dist && zip -r ../lambda.zip index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@playcanvas/splat-transform": "^1.10.2",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@testcontainers/localstack": "^11.13.0",
    "@types/aws-lambda": "^8.10.138",
    "@types/jest": "^29.5.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.0.0",
    "aws-sdk-client-mock": "^4.0.0",
    "esbuild": "^0.25.12",
    "jest": "^29.5.0",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
